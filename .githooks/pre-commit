#!/bin/sh
#
# Pre-commit hook: megakadályozza az em-dash (—) és en-dash (–) bekerülését.
#
# Telepítés (a repó gyökeréből, egyszer):
#   git config core.hooksPath .githooks
#
# A staged Markdown fájlokat ellenőrzi. Ha tiltott gondolatjelet talál,
# a commit megáll. Automatikus javítás:
#   node scripts/check-dashes.js --fix

# Csak a staged, hozzáadott/módosított .md fájlok.
staged_md=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$')

if [ -z "$staged_md" ]; then
  exit 0
fi

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: a node nem található, a gondolatjel-ellenőrzés kimarad." >&2
  exit 0
fi

# shellcheck disable=SC2086
node scripts/check-dashes.js $staged_md
status=$?

if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "A commit megállt: tiltott gondolatjel (— vagy –) található." >&2
  echo "Javítsd: node scripts/check-dashes.js --fix  majd: git add -A" >&2
  exit 1
fi

exit 0
